{
  "name": "bgblur-mcp",
  "version": "0.1.0",
  "description": "Official MCP server for BGBlur public API tools.",
  "type": "module",
  "bin": {
    "bgblur-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:http": "tsx src/http-server.ts",
    "build": "tsup src/server.ts src/http-server.ts --format esm --dts --clean",
    "build:http": "tsup src/http-server.ts --format esm --dts --clean",
    "start": "node dist/server.js",
    "start:http": "node dist/http-server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^20.19.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
