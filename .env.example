# ─────────────────────────────────────────────────────────────────────────────
# BGBlur MCP Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Required for STDIO server (local Claude Desktop, Cursor, CLI tools).
# Not needed for the HTTP server — users send their own key as Bearer token.
BGBLUR_API_KEY=your_bgblur_api_key

# Optional: API base URL (override for staging/testing)
BGBLUR_API_BASE_URL=https://bgblur.com/api/v1

# Optional: Request timeout in milliseconds (default: 120000)
BGBLUR_TIMEOUT_MS=120000

# ─── HTTP server settings ─────────────────────────────────────────────────────

PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed Host headers for DNS rebinding protection
ALLOWED_HOSTS=mcp.bgblur.com,localhost

# ─── OAuth 2.1 settings (for web Claude / ChatGPT support) ───────────────────
#
# These tell the MCP server how to advertise the bgblur.com OAuth endpoints so
# that web clients can redirect users through the standard authorization-code
# flow (with PKCE).  Set them to your production URLs before deploying.
#
# MCP_SERVER_URL   — public URL of THIS server (used in the OAuth discovery doc)
# BGBLUR_OAUTH_*   — bgblur.com's OAuth 2.1 authorization server endpoints
#
MCP_SERVER_URL=https://mcp.bgblur.com

BGBLUR_OAUTH_ISSUER=https://www.bgblur.com
BGBLUR_OAUTH_AUTHORIZE=https://www.bgblur.com/oauth/authorize
BGBLUR_OAUTH_TOKEN=https://www.bgblur.com/oauth/token
BGBLUR_OAUTH_REGISTER=https://www.bgblur.com/oauth/register